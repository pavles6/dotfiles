{{ if eq .chezmoi.os "linux" -}}

#!/bin/sh
sudo pacman -S --noconfirm {{ range .packages.linux.pacman }}{{ . }} {{ end }}

{{ else if eq .chezmoi.os "darwin" }}
#!/bin/zsh

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ end -}}
